<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voclio"
            android:textColor="#7C5CFC"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_month"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="June 2026"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#111827"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/week_strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_0_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_0_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="1" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_0_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_0_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_1_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_1_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="2" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_1_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_1_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_2_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_2_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="3" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_2_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_2_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_3_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_3_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="4" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_3_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_3_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_4_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_4_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="5" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_4_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_4_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_5_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_5_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="6" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_5_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_5_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
            <TextView android:id="@+id/day_6_dow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S" android:textColor="#9CA3AF" android:textSize="10sp" />
            <TextView android:id="@+id/day_6_num" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginTop="2dp" android:background="@drawable/widget_day_default" android:gravity="center" android:text="7" android:textColor="#111827" android:textSize="12sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="6dp" android:layout_marginTop="3dp" android:gravity="center" android:orientation="horizontal">
                <View android:id="@+id/day_6_task_dot" android:layout_width="4dp" android:layout_height="4dp" android:layout_marginEnd="2dp" android:background="@drawable/widget_task_indicator" android:visibility="gone" />
                <View android:id="@+id/day_6_note_dot" android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/widget_note_indicator" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="#11000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:textColor="#7C5CFC"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/task_item_1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/task_item_2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tasks_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="No tasks today"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#11000000" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textColor="#34C759"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/note_item_1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/note_item_2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#111827"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/notes_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="No notes yet"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
